# Copy this file to .env and fill in your AI provider credentials
# For OpenRouter:
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter-llama2-7b
OPENROUTER_URL=https://api.openrouter.ai/v1/chat/completions

# Fallback generic provider example:
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.qroq.ai/v1/chat
AI_API_MODEL=your_model_name

FLASK_ENV=development
